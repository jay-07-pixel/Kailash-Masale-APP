<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- Back Button -->
    <FrameLayout
        android:id="@+id/back_button_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="50dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="12dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_back_button" />
    </FrameLayout>

    <TextView
        android:id="@+id/page_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:fontFamily="@font/inter_font_family"
        android:text="Monthly Plan"
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/back_button_container"
        app:layout_constraintStart_toEndOf="@id/back_button_container"
        app:layout_constraintTop_toTopOf="@id/back_button_container" />

    <!-- Year and Month selectors -->
    <LinearLayout
        android:id="@+id/selector_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/back_button_container">

        <TextView
            android:id="@+id/year_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_semibold"
            android:text="Year:-"
            android:textColor="#000000"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/year_spinner"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/year_spinner_background"
            android:popupBackground="@android:color/white"
            android:paddingStart="6dp"
            android:paddingEnd="22dp"
            android:minWidth="70dp"
            android:dropDownVerticalOffset="28dp"
            android:spinnerMode="dropdown" />

        <TextView
            android:id="@+id/month_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/inter_semibold"
            android:text="Month:-"
            android:textColor="#000000"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/month_spinner"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/year_spinner_background"
            android:popupBackground="@android:color/white"
            android:paddingStart="6dp"
            android:paddingEnd="24dp"
            android:minWidth="90dp"
            android:dropDownVerticalOffset="28dp"
            android:spinnerMode="dropdown" />
    </LinearLayout>

    <!-- Scrollable table with editable Target column + Total row -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/selector_container"
        app:layout_constraintBottom_toTopOf="@id/submit_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/table_border_background"
                android:padding="1.5dp"
                android:clipToPadding="false">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="6.5dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/white"
                            android:orientation="vertical">

                            <!-- Header: D.N | W.D | LMA | Target | Ins (all text centered in cell) -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:background="#34404F"
                                android:orientation="horizontal"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1.2"
                                    android:gravity="center"
                                    android:fontFamily="@font/inter_font_family"
                                    android:text="D.N"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:paddingStart="38dp"
                                    android:fontFamily="@font/inter_font_family"
                                    android:text="W.D"
                                    android:textColor="@android:color/white"
                                    android:textSize="9sp"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:paddingStart="38dp"
                                    android:fontFamily="@font/inter_font_family"
                                    android:text="LMA"
                                    android:textColor="@android:color/white"
                                    android:textSize="9sp"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="92dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:paddingStart="20dp"
                                    android:fontFamily="@font/inter_font_family"
                                    android:text="Target"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:fontFamily="@font/inter_font_family"
                                    android:text="Ins"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Data rows filled from Firebase (assigned distributors + monthly_data) -->
                            <LinearLayout
                                android:id="@+id/monthly_plan_rows_container"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical" />

                            <!-- Spacer: pushes Total row to bottom of table -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:background="@android:color/white" />

                            <!-- Total row: same 5 columns -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="#2C3840"
                                android:orientation="horizontal"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="12dp"
                                android:paddingBottom="12dp"
                                android:gravity="center_vertical"
                                android:minHeight="40dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.2"
                                    android:fontFamily="@font/inter_font_family"
                                    android:gravity="end|center_vertical"
                                    android:text="Total"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/inter_font_family"
                                    android:gravity="end|center_vertical"
                                    android:text="₹"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/inter_font_family"
                                    android:gravity="end|center_vertical"
                                    android:text="₹"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp" />

                                <TextView
                                    android:layout_width="72dp"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter_font_family"
                                    android:gravity="end|center_vertical"
                                    android:text="₹"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/inter_font_family"
                                    android:gravity="end|center_vertical"
                                    android:text="₹"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Column dividers overlay -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1.2" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="#D0D0D0" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="#D0D0D0" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="#D0D0D0" />

                            <View
                                android:layout_width="92dp"
                                android:layout_height="match_parent" />

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="#D0D0D0" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />
                        </LinearLayout>
                    </FrameLayout>
                </androidx.cardview.widget.CardView>
            </FrameLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Submit button: save plan to Firebase -->
    <TextView
        android:id="@+id/submit_button"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:background="#34404F"
        android:gravity="center"
        android:text="Submit"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:fontFamily="@font/inter_font_family"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

