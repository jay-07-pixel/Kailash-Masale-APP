<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- Back Button (Productivity-style) -->
    <FrameLayout
        android:id="@+id/back_button_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="50dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="12dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="false"
            android:focusable="false"
            android:contentDescription="Back"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_back_button" />
    </FrameLayout>

    <TextView
        android:id="@+id/page_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:fontFamily="@font/inter_font_family"
        android:text="Monthly Plan"
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/back_button_container"
        app:layout_constraintStart_toEndOf="@id/back_button_container"
        app:layout_constraintTop_toTopOf="@id/back_button_container" />

    <!-- Add New Month button (below header title, right-aligned) -->
    <LinearLayout
        android:id="@+id/add_new_month_button"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:background="@drawable/add_week_button_background"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/back_button_container"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_add_plus"
            android:tint="@android:color/white"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="@font/inter_font_family"
            android:text="Add New Month"
            android:textColor="@android:color/white"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Plan approval status (above year dropdown) -->
    <LinearLayout
        android:id="@+id/plan_status_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/add_new_month_button">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_semibold"
            android:text="Plan status: "
            android:textColor="#000000"
            android:textSize="13sp" />
        <TextView
            android:id="@+id/plan_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_font_family"
            android:text="—"
            android:textColor="#555555"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Year and Month selectors + edit icon (right-aligned below Add New Month, with space) -->
    <LinearLayout
        android:id="@+id/selector_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/plan_status_container"
        app:layout_constraintBottom_toTopOf="@id/scroll_view">

        <TextView
            android:id="@+id/year_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_semibold"
            android:text="Year:-"
            android:textColor="#000000"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/year_spinner"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/year_spinner_background"
            android:popupBackground="@android:color/white"
            android:paddingStart="6dp"
            android:paddingEnd="22dp"
            android:minWidth="70dp"
            android:dropDownVerticalOffset="28dp"
            android:spinnerMode="dropdown" />

        <TextView
            android:id="@+id/month_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/inter_semibold"
            android:text="Month:-"
            android:textColor="#000000"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/month_spinner"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/year_spinner_background"
            android:popupBackground="@android:color/white"
            android:paddingStart="6dp"
            android:paddingEnd="24dp"
            android:minWidth="90dp"
            android:dropDownVerticalOffset="28dp"
            android:spinnerMode="dropdown" />

        <!-- Spacer to push edit icon to the right -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/edit_plan_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Edit plan"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_edit_pencil"
            android:padding="4dp" />
    </LinearLayout>

    <!-- Scrollable table (Productivity-style) -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:layout_marginTop="0dp"
        app:layout_constraintTop_toBottomOf="@id/selector_container"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- Table container (expands to fill; Total row at bottom) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/table_border_background"
                android:padding="1.5dp"
                android:clipToPadding="false">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardCornerRadius="6.5dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/white"
                            android:orientation="vertical">

                            <!-- Table header: D.N | W.D | LMA | Target | Ins (all text centered in cell) -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:background="#34404F"
                                android:orientation="horizontal"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1.2"
                                    android:gravity="center"
                                    android:fontFamily="@font/inter_font_family"
                                    android:text="D.N"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/incentive_header_text"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:fontFamily="@font/inter_font_family"
                                    android:text="W.D"
                                    android:textColor="@android:color/white"
                                    android:textSize="12sp"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/lma_header_text"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:paddingStart="25dp"
                                    android:fontFamily="@font/inter_font_family"
                                    android:text="LMA"
                                    android:textColor="@android:color/white"
                                    android:textSize="12sp"
                                    android:ellipsize="end"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="92dp"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:fontFamily="@font/inter_font_family"
                                    android:text="Target"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:fontFamily="@font/inter_font_family"
                                    android:text="Ins"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Data rows: loaded from Firebase monthly_data for selected year/month -->
                            <LinearLayout
                                android:id="@+id/monthly_plan_rows_container"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical" />

                            <!-- Spacer: pushes Total row to bottom of table -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:background="@android:color/white" />

                            <!-- Total row: same 5 columns -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="#2C3840"
                                android:orientation="horizontal"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="12dp"
                                android:paddingBottom="12dp"
                                android:gravity="center_vertical"
                                android:minHeight="40dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.2"
                                    android:fontFamily="@font/inter_font_family"
                                    android:gravity="start|center_vertical"
                                    android:text="Total"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/total_wd"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/inter_font_family"
                                    android:gravity="center"
                                    android:text="0"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/total_lma"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/inter_font_family"
                                    android:gravity="center"
                                    android:text="0"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/total_target"
                                    android:layout_width="92dp"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter_font_family"
                                    android:gravity="center"
                                    android:text="0"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/total_incentive"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/inter_font_family"
                                    android:gravity="center"
                                    android:text="0"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Column dividers overlay (Productivity-style, #D0D0D0) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="top">

                            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.2" />
                            <View android:layout_width="16dp" android:layout_height="match_parent" />
                            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#D0D0D0" />
                            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#D0D0D0" />
                            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#D0D0D0" />
                            <View android:layout_width="92dp" android:layout_height="match_parent" />
                            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#D0D0D0" />
                            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                        </LinearLayout>
                    </FrameLayout>
                </androidx.cardview.widget.CardView>
            </FrameLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom navigation (same as Dashboard) -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@drawable/bottom_nav_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/grid_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="30dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Calendar View"
            android:scaleType="fitCenter"
            android:src="@drawable/calender_final_icon" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/upload_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="20dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Upload"
            android:scaleType="fitCenter"
            android:src="@drawable/upload_final_icon" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/check_in_out_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="8dp"
            android:paddingEnd="20dp"
            android:paddingBottom="8dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_font_family"
                android:text="Check"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_font_family"
                android:text="IN/OUT"
                android:textColor="@android:color/white"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
