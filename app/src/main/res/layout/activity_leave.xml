<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- Back Button -->
    <FrameLayout
        android:id="@+id/back_button_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="50dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="12dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:background="@android:color/transparent"
            android:contentDescription="Back"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_back_button" />
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/page_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:fontFamily="@font/inter_font_family"
        android:text="Leave"
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/back_button_container"
        app:layout_constraintStart_toEndOf="@id/back_button_container"
        app:layout_constraintTop_toTopOf="@id/back_button_container" />

    <!-- Choice: Leave | Work on Sunday -->
    <LinearLayout
        android:id="@+id/choice_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/back_button_container">

        <TextView
            android:id="@+id/choice_leave"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/leave_submit_button_background"
            android:gravity="center"
            android:text="Leave"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:fontFamily="@font/inter_font_family"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/choice_work_sunday"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="#E0E0E0"
            android:gravity="center"
            android:text="Work on Sunday"
            android:textColor="#424242"
            android:textSize="14sp"
            android:fontFamily="@font/inter_font_family"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- ScrollView for both forms -->
    <ScrollView
        android:id="@+id/leave_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/choice_container"
        app:layout_constraintBottom_toTopOf="@id/application_date_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

    <!-- Leave form card (subject/name/leave dates/description) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/leave_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Subject -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_semibold"
                    android:text="Subject:-"
                    android:textColor="#000000"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/subject_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:hint=""
                    android:padding="0dp"
                    android:inputType="textCapSentences"
                    android:textColor="#000000"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="#E0E0E0" />

            <!-- Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_semibold"
                    android:text="Name:-"
                    android:textColor="#000000"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/name_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:hint=""
                    android:padding="0dp"
                    android:inputType="textCapWords"
                    android:textColor="#000000"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="#E0E0E0" />

            <!-- Leave Dates row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_semibold"
                    android:text="Leave Dates:-"
                    android:textColor="#000000"
                    android:textSize="14sp" />

                <!-- From date -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/leave_from_date"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="-"
                        android:padding="0dp"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:focusable="false" />

                    <ImageButton
                        android:id="@+id/from_date_button"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Select from date"
                        android:scaleType="fitCenter"
                        android:src="@drawable/fluent_calendar_month_24_regular" />
                </LinearLayout>

                <!-- Dash between dates -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="-"
                    android:textColor="#000000"
                    android:textSize="14sp" />

                <!-- To date -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/leave_to_date"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="-"
                        android:padding="0dp"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:focusable="false" />

                    <ImageButton
                        android:id="@+id/to_date_button"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Select to date"
                        android:scaleType="fitCenter"
                        android:src="@drawable/fluent_calendar_month_24_regular" />
                </LinearLayout>
            </LinearLayout>

            <!-- Big multiline text area -->
            <EditText
                android:id="@+id/leave_reason_input"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="12dp"
                android:background="@android:color/transparent"
                android:gravity="top|start"
                android:hint="Enter Your Text here"
                android:padding="0dp"
                android:inputType="textMultiLine"
                android:textColor="#000000"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Work on Sunday form card (Subject, Name, Select Sunday, Text) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/sunday_work_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_semibold"
                android:text="Subject:-"
                android:textColor="#000000"
                android:textSize="14sp" />
            <EditText
                android:id="@+id/sunday_subject_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent"
                android:hint="e.g. Work on Sunday"
                android:inputType="textCapSentences"
                android:textColor="#000000"
                android:textSize="14sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="8dp" android:background="#E0E0E0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/inter_semibold"
                android:text="Name:-"
                android:textColor="#000000"
                android:textSize="14sp" />
            <EditText
                android:id="@+id/sunday_name_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent"
                android:inputType="textCapWords"
                android:textColor="#000000"
                android:textSize="14sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="8dp" android:background="#E0E0E0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/inter_semibold"
                android:text="Select Sunday (pick one day):-"
                android:textColor="#000000"
                android:textSize="14sp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <EditText
                    android:id="@+id/sunday_date_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Tap to select a Sunday"
                    android:padding="0dp"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:focusable="false"
                    android:clickable="true" />
                <ImageButton
                    android:id="@+id/sunday_date_button"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Select Sunday"
                    android:scaleType="fitCenter"
                    android:src="@drawable/fluent_calendar_month_24_regular" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/inter_font_family"
                android:text="Only Sundays can be selected."
                android:textColor="#757575"
                android:textSize="12sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="8dp" android:background="#E0E0E0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/inter_semibold"
                android:text="Reason / Notes:-"
                android:textColor="#000000"
                android:textSize="14sp" />
            <EditText
                android:id="@+id/sunday_reason_input"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent"
                android:gravity="top|start"
                android:hint="Enter your text here"
                android:inputType="textMultiLine"
                android:textColor="#000000"
                android:textSize="14sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

            <!-- My applications: status of submitted leave / work on Sunday -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/inter_font_family"
                android:text="My applications"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/inter_font_family"
                android:text="See if your leave or work on Sunday request is approved."
                android:textColor="#666666"
                android:textSize="12sp" />
            <LinearLayout
                android:id="@+id/my_applications_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

    <!-- Application date (fixed at bottom area) -->
    <TextView
        android:id="@+id/application_date_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="4dp"
        android:fontFamily="@font/inter_semibold"
        android:text="Application date :- 18/12/2025"
        android:textColor="#34404F"
        android:textSize="13sp"
        app:layout_constraintBottom_toTopOf="@id/submit_button"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Submit button (AppCompatButton so theme does not override background with purple) -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/submit_button"
        android:layout_width="160dp"
        android:layout_height="44dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/leave_submit_button_background"
        app:backgroundTint="@null"
        android:stateListAnimator="@null"
        android:text="Submit"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:fontFamily="@font/inter_font_family"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

