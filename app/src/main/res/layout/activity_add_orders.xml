<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".AddOrdersActivity">

    <!-- Header with Back Button and Title -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="50dp"
        android:paddingBottom="16dp"
        android:background="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/back_button_container"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/back_button"
                android:layout_width="12dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_back_button" />
        </FrameLayout>

        <TextView
            android:id="@+id/page_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/inter_font_family"
            android:text="Add Orders"
            android:textColor="#34404F"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/back_button_container"
            app:layout_constraintStart_toEndOf="@id/back_button_container"
            app:layout_constraintTop_toTopOf="@id/back_button_container" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Select Distributor Section -->
            <TextView
                android:id="@+id/distributor_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_font_family"
                android:text="Select Distributor"
                android:textColor="#34404F"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/distributor_spinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/add_orders_spinner_background"
                android:paddingStart="16dp"
                android:paddingEnd="40dp"
                android:popupBackground="@drawable/spinner_dropdown_background"
                android:dropDownSelector="@drawable/spinner_dropdown_background"
                android:theme="@style/Theme.AppCompat.Light.NoActionBar"
                android:dropDownVerticalOffset="48dp"
                android:layout_marginBottom="16dp" />

            <!-- Select Date Section -->
            <TextView
                android:id="@+id/order_date_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_font_family"
                android:text="Select Date"
                android:textColor="#34404F"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/order_date_input"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/add_orders_spinner_background"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:fontFamily="@font/inter_font_family"
                android:textColor="#34404F"
                android:textSize="16sp"
                android:inputType="none"
                android:focusable="false"
                android:clickable="true"
                android:cursorVisible="false"
                android:layout_marginBottom="16dp" />

            <!-- Submitted orders for this distributor & date -->
            <LinearLayout
                android:id="@+id/submitted_orders_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="@drawable/add_orders_spinner_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/submitted_orders_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_font_family"
                    android:text="Submitted orders"
                    android:textColor="#34404F"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/submitted_orders_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Limit reached: 4 orders already placed for this distributor/date -->
            <LinearLayout
                android:id="@+id/order_limit_reached_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/add_orders_spinner_background"
                android:padding="16dp">

                <TextView
                    android:id="@+id/order_limit_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_font_family"
                    android:text="You have already placed 20 orders for this distributor on this date. No more orders can be added."
                    android:textColor="#34404F"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_font_family"
                    android:text="Orders placed:"
                    android:textColor="#34404F"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/order_placed_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Orders Section -->
            <TextView
                android:id="@+id/orders_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_font_family"
                android:text="Orders"
                android:textColor="#34404F"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <!-- Order Items Container -->
            <LinearLayout
                android:id="@+id/order_items_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Order Item 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1."
                        android:textColor="#34404F"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_font_family"
                        android:layout_marginEnd="12dp" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/add_order_item_1"
                            android:layout_width="54dp"
                            android:layout_height="23dp"
                            android:background="@drawable/order_item_plus_button"
                        android:backgroundTint="@null"
                        android:text="+"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:padding="0dp"
                        android:paddingTop="-2dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:gravity="center"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <!-- Order Item 2 -->
                <LinearLayout
                    android:id="@+id/order_item_2_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2."
                        android:textColor="#34404F"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_font_family"
                        android:layout_marginEnd="12dp" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/add_order_item_2"
                            android:layout_width="54dp"
                            android:layout_height="23dp"
                            android:background="@drawable/order_item_plus_button"
                            android:backgroundTint="@null"
                            android:text="+"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:padding="0dp"
                            android:paddingTop="-2dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:visibility="gone" />
                </LinearLayout>

                <!-- Order Item 3 -->
                <LinearLayout
                    android:id="@+id/order_item_3_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3."
                        android:textColor="#34404F"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_font_family"
                        android:layout_marginEnd="12dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/add_order_item_3"
                        android:layout_width="54dp"
                        android:layout_height="23dp"
                        android:background="@drawable/order_item_plus_button"
                        android:backgroundTint="@null"
                        android:text="+"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:padding="0dp"
                        android:paddingTop="-2dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- Order Item 4 -->
                <LinearLayout
                    android:id="@+id/order_item_4_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4."
                        android:textColor="#34404F"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_font_family"
                        android:layout_marginEnd="12dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/add_order_item_4"
                        android:layout_width="54dp"
                        android:layout_height="23dp"
                        android:background="@drawable/order_item_plus_button"
                        android:backgroundTint="@null"
                        android:text="+"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:padding="0dp"
                        android:paddingTop="-2dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:visibility="gone" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Submit Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/submit_button"
        android:layout_width="283dp"
        android:layout_height="40dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/dialog_save_button"
        android:backgroundTint="@null"
        android:text="Submit"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/inter_font_family"
        android:textAllCaps="false"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@drawable/bottom_nav_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/grid_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="30dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Calendar View"
            android:scaleType="fitCenter"
            android:src="@drawable/calender_final_icon" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/upload_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="20dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Upload"
            android:scaleType="fitCenter"
            android:src="@drawable/upload_final_icon" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/check_in_out_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="8dp"
            android:paddingEnd="20dp"
            android:paddingBottom="8dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_font_family"
                android:text="Check"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_font_family"
                android:text="IN/OUT"
                android:textColor="@android:color/white"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
