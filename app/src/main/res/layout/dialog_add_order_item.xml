<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialog_card"
    android:layout_width="317dp"
    android:layout_height="wrap_content"
    android:minHeight="380dp"
    android:layout_gravity="center"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- SKU Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SKU"
            android:textColor="#34404F"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_font_family"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/sku_search_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/dialog_input_field_background"
            android:hint="Search SKU..."
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#34404F"
            android:textColorHint="#BDBDBD"
            android:textSize="14sp"
            android:fontFamily="@font/inter_font_family"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:layout_marginBottom="4dp" />

        <ListView
            android:id="@+id/sku_list"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/dialog_input_field_background"
            android:padding="4dp"
            android:divider="#E0E0E0"
            android:dividerHeight="1dp"
            android:scrollbars="vertical"
            android:layout_marginBottom="4dp"
            android:elevation="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/sku_selected_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#34404F"
            android:textSize="13sp"
            android:fontFamily="@font/inter_font_family"
            android:layout_marginBottom="20dp"
            android:visibility="gone" />

        <!-- KG Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KG"
            android:textColor="#34404F"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_font_family"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/kg_edittext"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/dialog_input_field_background"
            android:hint="Total KG"
            android:inputType="numberDecimal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#34404F"
            android:textColorHint="#BDBDBD"
            android:textSize="14sp"
            android:fontFamily="@font/inter_font_family"
            android:layout_marginBottom="20dp" />

        <!-- Scheme Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scheme"
            android:textColor="#34404F"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_font_family"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/scheme_edittext"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/dialog_input_field_background"
            android:hint="Enter Scheme"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#34404F"
            android:textColorHint="#BDBDBD"
            android:textSize="14sp"
            android:fontFamily="@font/inter_font_family"
            android:layout_marginBottom="24dp" />

            <!-- Save Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/save_button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/dialog_save_button"
                android:backgroundTint="@null"
                android:text="Save"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_font_family"
                android:textAllCaps="false" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
