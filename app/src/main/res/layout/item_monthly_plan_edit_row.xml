<?xml version="1.0" encoding="utf-8"?>
<!-- Row: D.N | W.D | LMA | Target | Incentive -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:gravity="center_vertical"
    android:minHeight="44dp"
    android:clipChildren="true"
    android:clipToPadding="true"
    android:background="@drawable/monthly_plan_row_grey">

    <TextView
        android:id="@+id/row_dn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:fontFamily="@font/inter_font_family"
        android:gravity="center_vertical|end"
        android:text=""
        android:textColor="#374151"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/row_wd"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingStart="24dp"
        android:paddingEnd="0dp"
        android:fontFamily="@font/inter_font_family"
        android:gravity="center_vertical|end"
        android:text="0"
        android:textColor="#374151"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/row_lma"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingStart="24dp"
        android:paddingEnd="0dp"
        android:fontFamily="@font/inter_font_family"
        android:gravity="center_vertical|end"
        android:text="0"
        android:textColor="#374151"
        android:textSize="13sp" />

    <!-- Target column: 92dp width; cells aligned right with left padding -->
    <LinearLayout
        android:layout_width="92dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|end"
        android:paddingStart="12dp">

        <FrameLayout
            android:id="@+id/row_target_cell"
            android:layout_width="72dp"
            android:layout_height="28dp"
            android:background="@drawable/target_cell_background"
            android:clickable="true"
            android:focusable="true"
            android:minWidth="48dp"
            android:minHeight="28dp"
            android:clipChildren="true"
            android:clipToOutline="true"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">

            <TextView
                android:id="@+id/row_target_value"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:textColor="#374151"
                android:textSize="12sp"
                android:fontFamily="@font/inter_font_family"
                android:singleLine="true"
                android:maxLines="1"
                android:ellipsize="end" />
        </FrameLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/row_incentive"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/inter_font_family"
        android:gravity="center_vertical|end"
        android:text="0"
        android:textColor="#374151"
        android:textSize="13sp" />
</LinearLayout>
