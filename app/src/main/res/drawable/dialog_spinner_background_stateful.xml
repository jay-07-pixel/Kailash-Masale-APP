                        android:color="#CCCCCC"/>
                </shape>
            </item>
            <item
                android:width="20dp"
                android:height="20dp"
                android:gravity="end|center_vertical"
                android:drawable="@drawable/ic_dropdown_arrow"
                android:end="16dp"/>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#FFFFFF"/>
                    <corners android:radius="12dp"/>
                    <stroke
                        android:width="1.5dp"
                        android:color="#CCCCCC"/>
                </shape>
            </item>
            <item
                android:width="20dp"
                android:height="20dp"
                android:gravity="end|center_vertical"
                android:drawable="@drawable/ic_dropdown_arrow"
                android:end="16dp"/>
        </layer-list>
    </item>
</selector>





