                android:gravity="end|center_vertical"
                android:drawable="@drawable/ic_dropdown_arrow"
                android:end="16dp"/>
        </layer-list>
    </item>
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#FFFFFF"/>
