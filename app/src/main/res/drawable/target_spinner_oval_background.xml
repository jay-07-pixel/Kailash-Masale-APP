<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Smaller pill around the arrow, filled with #EAEAEA -->
    <item
        android:left="6dp"
        android:right="6dp"
        android:top="4dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#EAEAEA" />
            <!-- Slightly smaller radius so pill looks compact -->
            <corners android:radius="12dp" />
            <stroke
                android:width="1dp"
                android:color="#D0D0D0" />
        </shape>
    </item>

    <!-- Dropdown arrow icon centered inside the pill -->
    <item
        android:width="16dp"
        android:height="16dp"
        android:gravity="center"
        android:drawable="@drawable/ic_dropdown_arrow" />
</layer-list>


