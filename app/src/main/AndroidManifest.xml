<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <supports-screens
        android:smallScreens="true"
        android:normalScreens="true"
        android:largeScreens="true"
        android:xlargeScreens="true"
        android:anyDensity="true"
        android:resizeable="true" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KAILASHMASALE"
        tools:targetApi="31">
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.KAILASHMASALE.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".DashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".CheckInOutActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".TargetAchievedActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".ProductivityActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".WorkingDaysActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".DAActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".TAActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".PerformanceActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".MonthlyPlanActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".AddOrdersActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".EmployeeDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".DistributorsActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".WeeklyPlannerActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".MonthlyAttendanceActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".AttendanceActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".MonthlyPlanEditActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".LeaveActivity"
            android:exported="false"
            android:theme="@style/Theme.KAILASHMASALE.ForceLight"
            android:windowSoftInputMode="adjustPan" />
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>